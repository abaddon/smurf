# Smurf orchestrator — environment variables
# Copy to .env (gitignored) and fill in real values. Never commit .env.

# === Anthropic / Claude Code ===
# Required for autonomous runs unless ANTHROPIC_BASE_URL points elsewhere.
# Most users get this from their Claude Code subscription rather than a
# raw API key — leave empty if running under subscription auth.
# ANTHROPIC_API_KEY=

# === GitHub ===
# Personal access token for the GitHub MCP server (.mcp.json).
# Scopes needed: repo, read:org, read:user.
GITHUB_TOKEN=

# === OpenRouter (Phase 6b — marketing + sales-feedback) ===
# Cheap-LLM provider used by the marketing and sales-feedback agents.
# Free tier ~50 req/day; $5 credit gets you ~5000 calls on Gemini Flash.
OPENROUTER_API_KEY=

# === Slack (optional — Phase 5) ===
# Incoming webhook URL. If set, autonomous-run.sh posts the run summary.
# SLACK_WEBHOOK=

# === Anthropic outage failover (optional — Phase 5 ops) ===
# Point at OpenRouter Anthropic Skin if first-party Anthropic is degraded.
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# ANTHROPIC_AUTH_TOKEN=$OPENROUTER_API_KEY

# === Optional MCP servers (Phase 7 — uncomment as wired up) ===
# LINEAR_API_KEY=
# SENTRY_AUTH_TOKEN=
# POSTMARK_SERVER_TOKEN=
